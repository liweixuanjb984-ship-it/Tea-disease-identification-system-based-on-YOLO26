.page {
  padding: 24rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #dce5df;
  border-radius: 8rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #143d2a;
}

.subtitle {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #66736c;
}

.actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.server-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  align-items: center;
}

.server-input {
  flex: 1;
  height: 76rpx;
  padding: 0 18rpx;
  background: #f5f7f6;
  border: 1rpx solid #dce5df;
  border-radius: 6rpx;
  font-size: 26rpx;
  color: #25362d;
}

.mini-btn {
  width: 150rpx;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0;
  background: #eef4f0;
  color: #1f5b3d;
  font-size: 26rpx;
}

.btn {
  flex: 1;
  background: #eef4f0;
  color: #1f5b3d;
  font-size: 28rpx;
}

.primary,
.detect-btn {
  background: #1f7a4d;
  color: #ffffff;
}

.detect-btn {
  margin-top: 24rpx;
  width: 100%;
  font-size: 30rpx;
}

.file-box {
  margin-top: 24rpx;
  padding: 18rpx;
  background: #f5f7f6;
  border-radius: 6rpx;
}

.file-label {
  font-size: 24rpx;
  color: #69776f;
}

.file-path {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #25362d;
  word-break: break-all;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.preview {
  width: 100%;
  border-radius: 6rpx;
}

.video {
  width: 100%;
  height: 420rpx;
  border-radius: 6rpx;
}

.summary {
  margin-top: 14rpx;
  font-size: 28rpx;
  color: #28382f;
}

.table {
  border: 1rpx solid #dce5df;
  border-radius: 6rpx;
  overflow: hidden;
}

.tr {
  display: flex;
  border-top: 1rpx solid #edf2ef;
}

.tr:first-child {
  border-top: 0;
}

.header {
  background: #f1f6f3;
  font-weight: 700;
}

.td {
  flex: 1;
  padding: 16rpx 12rpx;
  font-size: 24rpx;
  color: #25362d;
  word-break: break-word;
}

.name {
  flex: 1.4;
}
